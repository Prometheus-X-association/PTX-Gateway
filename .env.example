# Frontend environment variables (safe to commit).
# Copy to `.env.local` for local development:
#   cp .env.example .env.local

# Required: Supabase API URL used by the frontend client.
# - Typical local value: http://127.0.0.1:54321 (or http://localhost:54321)
# - WSL + host browser: use your WSL IP (example: http://172.x.x.x:54321)
VITE_SUPABASE_URL=http://127.0.0.1:54321

# Required: Supabase publishable/anon key used by the frontend client.
# Get from `npx supabase status` (local) or your hosted Supabase project settings.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Optional: Label only (not used for auth/runtime logic).
VITE_SUPABASE_PROJECT_ID=local

# Optional: Design url for the app
VITE_DESIGN_THEME_URL= #DESIGN-URL
